# Django Settings
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# Database (MySQL)
DB_NAME=document_intelligence
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# AI Settings
# Set USE_LM_STUDIO=True to use local LM Studio (recommended)
# Set USE_LM_STUDIO=False and add API keys for OpenAI/Anthropic
USE_LM_STUDIO=True
LM_STUDIO_URL=http://localhost:1234/v1

# OpenAI API (if not using LM Studio)
OPENAI_API_KEY=your-openai-api-key

# Anthropic API (if not using LM Studio)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Celery/Redis (optional, for async processing)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Cache
CACHE_TYPE=redis
CACHE_REDIS_HOST=localhost
CACHE_REDIS_PORT=6379
